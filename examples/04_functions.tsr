fn greet(name) {
  say("Hello, " + name + "!");
}

fn add(a, b) {
  return a + b;
}

fn factorial(n) {
  if (n <= 1) {
    return 1;
  }
  return n * factorial(n - 1);
}

greet("World");
greet("TSR");

let result = add(3, 4);
say("3 + 4 = " + to_string(result));

say("5! = " + to_string(factorial(5)));
